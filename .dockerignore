# ============================================
# .dockerignore - 排除不需要打包进镜像的文件
# ============================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# 虚拟环境
venv/
.venv/
env/
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# 系统文件
Thumbs.db
.DS_Store
Desktop.ini

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile
.dockerignore
docker-compose*.yml
docker-compose*.yaml

# 文档
README.md
*.md

# 临时文件
*.log
*.pid
*.tar
*.tar.gz
*.zip

# 环境变量文件（通过 config.py 硬编码配置，无需 .env）
.env
.env.local
.env.production

# 上传文件（运行时挂载）
uploads/